model Match {
  id String @id @default(uuid())

  title String?

  // Ownership
  academyId String?
  academy   Academy? @relation(fields: [academyId], references: [id], onDelete: SetNull)

  clubId String?
  club   Club? @relation(fields: [clubId], references: [id], onDelete: SetNull)

  leagueId String?
  league   League? @relation(fields: [leagueId], references: [id], onDelete: SetNull)

  // Teams (STRICT: 2 teams only)
  homeTeamId String
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  
  awayTeamId String
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  matchType MatchType
  status    MatchStatus @default(SCHEDULED)

  kickoffAt DateTime
  venueName String?
  venueAddress String?

  referees String? 

  matchCostId String?  @unique
  matchCost   MatchCost? @relation(fields: [matchCostId], references: [id], onDelete: SetNull)

  additionalNotes String?

  // Relations
  gameReport      GameReport?
  matchStatistics MatchStatistics[]
  matchMedia      MatchMedia[]
  extraEvents     ExtraEvents[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([academyId])
  @@index([leagueId])
  @@index([homeTeamId])
  @@index([awayTeamId])

  @@map("matches")
}

model MatchCost {
  id              String  @id @default(uuid())
  matchId         String  @unique
  match           Match   @relation(fields: [matchId], references: [id], onDelete: Cascade)
  transportation  Float?  @default(0)
  mealCost        Float?  @default(0)
  otherCost       Float?  @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([matchId])
  @@map("match_costs")
}

model GameReport {
  id              String        @id @default(uuid())
  playerId        String
  player          Player        @relation(fields: [playerId], references: [id], onDelete: Cascade)
  
  matchId         String        @unique
  match           Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)

  myTeamId        String
  myTeam          Team          @relation(fields: [myTeamId], references: [id], onDelete: Cascade)

  position        String?  
  foot        String?  
  characteristics String[]
  weight          Int?     
  height          Int?    
  matchPlayed     Int?
  minutesPlayed   Int?
  manOfTheMatch   Boolean?      @default(false)
  scoutName       String?
  gameType        String?  
  gameDate        DateTime? @map("game_date")
  location        String?   
  matchResult     String?   @map("match_result")
  weather         String?   
  rating          Float?
  additionalNumber Int? @default(0)
  paymentStatus   PaymentStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([playerId])
  @@map("game_reports")
}

model MatchStatistics {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  // Specific stats can be added here
  
  @@index([matchId])
  @@map("match_statistics")
}

model MatchMedia {
  id      String @id @default(uuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  url     String
  type    MediaType @default(IMAGE)
  caption String?

  @@index([matchId])
  @@map("match_media")
}

model ExtraEvents {
  id              String    @id @default(uuid())
  academyId       String?
  academy         Academy?  @relation(fields: [academyId], references: [id], onDelete: SetNull)

  name            String?
  type            String?
  targetAttendees String?
  date            DateTime?
  startTime       String?
  endTime         String?
  registrationDeadline     DateTime?
  venueName          String?
  fullAddress      String?
  maxCapacity     Int?
  eventFee      Int?

  description     String?
  requirements    String?
  contactPersonName     String?
  contactEmail    String?
  contactPhone    String?
  image           String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId])
  @@index([academyId])
  @@map("extra_events")
}

model TrainingSession {
  id              String          @id @default(uuid())
  sessionName     String?
  teamId          String?
  team            Team?           @relation(fields: [teamId], references: [id], onDelete: SetNull)
  headCoachId     String?
  headCoach       Coach?          @relation(fields: [headCoachId], references: [id], onDelete: SetNull)
  date            DateTime?
  startTime       String?
  endTime         String?
  location        String?
  sessionType     String?
  focusArea       String?
  maxParticipants Int?
  description     String?
  requiredEquip   String?
  additionalNotes String?
  
  players         SessionPlayer[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId])
  @@index([headCoachId])
  @@map("training_sessions")
}

model SessionPlayer {
  id          String          @id @default(uuid())
  sessionId   String
  session     TrainingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId    String
  player      Player          @relation(fields: [playerId], references: [id], onDelete: Cascade)
  presentType String?         // Present, Absent, Late

  @@index([sessionId])
  @@index([playerId])
  @@map("session_players")
}

model CoachComment {
  id       String  @id @default(uuid())
  coachId  String
  coach    Coach   @relation(fields: [coachId], references: [id], onDelete: Cascade)
  playerId String
  player   Player  @relation(fields: [playerId], references: [id], onDelete: Cascade)
  comment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([coachId])
  @@index([playerId])
  @@map("coach_comments")
}
