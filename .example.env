# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
BACKEND_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local
DATABASE_URL=postgresql://postgres:password@localhost:5432/fantasy_ufc?schema=public
# Docker
# DATABASE_URL=postgresql://postgres:password@db:5432/fantasy_ufc?schema=public

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local
REDIS_URL=redis://127.0.0.1:6379
# Docker
# REDIS_URL=redis://redis:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUND=10
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_EXPIRE_IN=7d
JWT_REFRESH_EXPIRE_IN=30d

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_FROM=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
NAME=Admin
EMAIL=admin@fantasylfc.com
PHONE=0000000000
PASSWORD=Admin@12345
AVATAR=https://i.ibb.co/VWkMFBWM/pngtree-user-icon-png-image-1796659.jpg